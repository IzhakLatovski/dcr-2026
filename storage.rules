rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // TODO: tighten before production
    match /{allPaths=**} {
      allow read, write: if true;
    }

    // Production rules (commented out during development):
    // // Plan proof files: each user owns their subfolder
